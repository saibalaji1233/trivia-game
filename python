import random
# Python trivia questions and answers
questions = {
"What is the keyword to define a function in Python?": "def",
"Which data type is used to store True or False values?": "boolean",
"What is the correct file extension for Python files?": ".py",
"Which symbol is used to comment in Python?": "#",
"What function is used to get input from the user?": "input",
"How do you start a for loop in Python?": "for",
"What is the output of 2 ** 3 in Python?": "8",
"What keyword is used to import a module in Python?": "import",
"What does the len() function return?": "length",
"What is the result of 10 // 3 in Python?": "3"
}
def play_trivia():
    score=0
    total_questions=5
    # convert questions into list
    question_list=list(questions.keys())
    # randomly choose 5 questions
    random_questions=random.sample(question_list,total_questions)
    for i,q in enumerate(random_questions,1):
        print(f"\nQuestion{i}:{q}")
        answer=input("Your answer:").strip().lower()
        # check answer
        if answer==questions[q].lower():
            print("Correct answer! ✅")
            score+=1
        else:
            print(f"Wrong answer ❌ Correct answer is:{questions[q]}")
    print("\nGame Finished!")
    print(f"Your Score:{score}/{total_questions}")
# start the game
play_trivia()

